# ============================================================
# Creem 支付环境变量配置
# 替代 Stripe，支持全球收款
# ============================================================

# Creem API 密钥（从 Creem Dashboard 获取）
CREEM_API_KEY=your_creem_api_key_here

# Creem Webhook 签名密钥（从 Creem Dashboard > Settings > Webhooks 获取）
CREEM_WEBHOOK_SECRET=your_creem_webhook_secret_here

# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx  # 重要：需要 service_role key 才能写入数据

# 应用 URL（用于支付成功/取消回调）
NEXT_PUBLIC_APP_URL=http://localhost:3000  # 开发环境
# NEXT_PUBLIC_APP_URL=https://your-domain.com  # 生产环境
