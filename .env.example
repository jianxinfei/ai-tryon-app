# ============================================================
# Stripe 集成环境变量配置
# ============================================================

# Stripe API 密钥（从 Stripe Dashboard 获取）
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Stripe Webhook 签名密钥（从 Stripe Dashboard > Webhooks 获取）
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx  # 重要：需要 service_role key 才能写入数据

# 应用 URL（用于支付成功/取消回调）
NEXT_PUBLIC_APP_URL=http://localhost:3000  # 开发环境
# NEXT_PUBLIC_APP_URL=https://your-domain.com  # 生产环境
